{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/wangxiuwen/coursebox/spec/manifest.schema.json",
  "title": "CourseBox Manifest",
  "description": "Schema for manifest.json inside a CourseBox course package.",
  "type": "object",
  "required": ["format", "version", "resources", "courses"],
  "properties": {
    "format": { "const": "parrot-course-package" },
    "version": { "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "generator": { "type": "string" },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/definitions/resource" }
    },
    "courses": {
      "type": "array",
      "items": { "$ref": "#/definitions/course" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "resource": {
      "type": "object",
      "required": ["hash", "path", "size", "type"],
      "properties": {
        "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "path": { "type": "string", "pattern": "^objects/[0-9a-f]{64}(\\.[A-Za-z0-9]+)?$" },
        "size": { "type": "integer", "minimum": 0 },
        "type": { "type": "string" },
        "origin": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "course": {
      "type": "object",
      "required": ["id", "title", "lessons_manifest"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "type": {
          "type": "string",
          "examples": ["audio_course", "nce", "chinese_poetry", "music"]
        },
        "lessons_manifest": { "type": "string", "pattern": "^objects/[0-9a-f]{64}\\.json$" },
        "lesson_index": {
          "type": "array",
          "items": { "$ref": "#/definitions/lessonIndexEntry" }
        },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "lessonIndexEntry": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "audio_hash": { "type": "string", "pattern": "^(sha256:[0-9a-f]{64})?$" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
